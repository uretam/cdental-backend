    <changeSet id="1-crear-tabla-pacientes" author="estudiante">
        <createTable tableName="pacientes">
            <column name="id_paciente" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="rut" type="VARCHAR(20)"/>
            <column name="nombres" type="VARCHAR(100)"/>
            <column name="apellidos" type="VARCHAR(100)"/>
            <column name="fecha_nacimiento" type="DATE"/>
            <column name="email" type="VARCHAR(100)"/>
            <column name="telefono" type="VARCHAR(20)"/>
            <column name="direccion" type="VARCHAR(200)"/>
            <column name="activo" type="BOOLEAN"/>
        </createTable>
    </changeSet>

