<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="1-crear-tabla-citas" author="estudiante">
        <createTable tableName="citas">
            <column name="id_cita" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="id_paciente" type="BIGINT"/>
            <column name="id_odontologo" type="BIGINT"/>
            <column name="fecha_hora" type="TIMESTAMP"/>
            <column name="motivo" type="VARCHAR(255)"/>
            <column name="estado" type="VARCHAR(50)"/>
            <column name="total_general" type="DECIMAL(10,2)"/>
        </createTable>
    </changeSet>

    <changeSet id="2-crear-tabla-detalle-citas" author="estudiante">
        <createTable tableName="detalle_citas">
            <column name="id_detalle" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="id_cita" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="id_treatment" type="BIGINT"/> <column name="cantidad" type="INT"/>
            <column name="precio_unitario" type="DECIMAL(10,2)"/>
            <column name="subtotal_linea" type="DECIMAL(10,2)"/>
            <column name="descripcion_tratamiento" type="VARCHAR(255)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="detalle_citas" baseColumnNames="id_cita"
                                 constraintName="fk_detalle_cita_cabecera"
                                 referencedTableName="citas" referencedColumnNames="id_cita"/>
    </changeSet>

