    <changeSet id="1-crear-tabla-odontologos" author="estudiante">
        <createTable tableName="odontologos">
            <column name="id_odontologo" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="matricula" type="VARCHAR(50)"/>
            <column name="nombres" type="VARCHAR(100)"/>
            <column name="apellidos" type="VARCHAR(100)"/>
            <column name="especialidad" type="VARCHAR(100)"/>
            <column name="telefono" type="VARCHAR(20)"/>
            <column name="activo" type="BOOLEAN"/>
        </createTable>
    </changeSet>

